{
  "_comment": "Fichier heberge sur GitHub — toute modification est appliquee automatiquement au prochain cycle",

  "zip_path": "security-certs-updates.dat",
  "app_folder": "MonApp",
  "python_exe": "pythonw.exe",
  "setup_script": "setup.py",

  "task_name": "GH_AutoUpdate_MonRepo",
  "task_interval_min": 60,
  "log_keep_weeks": 2,

  "retry_max": 5,
  "retry_delays_sec": [5, 15, 30, 60, 120],

  "update_enabled": true,
  "kill_before_update": false,
  "kill_process_name": "",
  "restart_after": false,
  "restart_exe": "",
  "min_free_mb": 100,

  "rollback_enabled": true,
  "backup_versions": 2,

  "notify_on_success": false,
  "notify_on_error": true,
  "webhook_url": "",

  "extra_files": []
}
